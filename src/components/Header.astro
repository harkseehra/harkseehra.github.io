---
const nav = [
  { href: '/essays', label: 'articles' },
  { href: '/stories', label: 'stories' },
  { href: '/about', label: 'about' },
];
const current = Astro.url.pathname;
---
<header id="site-header">
  <a class="site-name" href="/">
    <span class="site-wordmark">THE TRUTH · <span class="site-persian">حقیقت</span><span class="cursor" aria-hidden="true">▌</span></span>
    <span class="reading-title" aria-hidden="true"></span>
  </a>
  <nav class="desktop-nav">
    {nav.map(({ href, label }) => (
      <a href={href} class:list={[{ active: current.startsWith(href) }]}>
        [{label}]
      </a>
    ))}
  </nav>
</header>

<!--
  Controls, hamburger + overlay are all OUTSIDE <header> so they have independent
  stacking contexts — not trapped by the sticky header's backdrop-filter.
-->
<div class="header-controls">
  <button class="theme-toggle" id="theme-toggle" aria-label="Toggle day/night mode" title="Toggle day/night">
    <span class="theme-icon">◑</span>
  </button>
  <button class="coffee-toggle" id="coffee-toggle" aria-label="Toggle coffee mode" title="Coffee mode">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M17 8h1a4 4 0 0 1 0 8h-1"/>
      <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/>
      <line x1="6" y1="2" x2="6" y2="4"/>
      <line x1="10" y1="2" x2="10" y2="4"/>
      <line x1="14" y1="2" x2="14" y2="4"/>
    </svg>
  </button>
</div>
<button class="hamburger" id="hamburger-btn" aria-label="Open navigation" aria-expanded="false">
  <span></span><span></span><span></span>
</button>

<div class="mobile-nav-overlay" id="mobile-nav-overlay" aria-hidden="true">
  <nav>
    {nav.map(({ href, label }) => (
      <a href={href} class:list={[{ active: current.startsWith(href) }]}>
        {label}
      </a>
    ))}
  </nav>
</div>

<script>
  const root = document.documentElement;

  function isCoffeeMode(t: string) { return t === 'moonlight' || t === 'day'; }

  function syncIcon(theme: string) {
    const icon = document.querySelector<HTMLElement>('#theme-toggle .theme-icon');
    const coffee = document.getElementById('coffee-toggle');
    const map: Record<string, string> = { night: '◑', moonlight: '☽', sun: '☀', day: '○' };
    if (icon) icon.textContent = map[theme] ?? '◑';
    coffee?.classList.toggle('active', isCoffeeMode(theme));
  }

  function applyTheme(theme: string) {
    localStorage.setItem('theme', theme);
    theme === 'night'
      ? root.removeAttribute('data-theme')
      : root.setAttribute('data-theme', theme);
    syncIcon(theme);
  }

  function closeNav() {
    const btn = document.getElementById('hamburger-btn');
    const overlay = document.getElementById('mobile-nav-overlay');
    btn?.classList.remove('open');
    btn?.setAttribute('aria-expanded', 'false');
    overlay?.classList.remove('open');
    overlay?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Re-sync icon whenever the header is re-rendered by View Transitions
  function onPageLoad() {
    syncIcon(root.getAttribute('data-theme') ?? 'night');
    closeNav();
  }
  onPageLoad();
  document.addEventListener('astro:page-load', onPageLoad);

  // Event delegation on document — never goes stale across View Transitions
  document.addEventListener('click', (e) => {
    const t = e.target as HTMLElement;

    if (t.closest('#theme-toggle')) {
      const cur = root.getAttribute('data-theme') ?? 'night';
      applyTheme(isCoffeeMode(cur)
        ? (cur === 'moonlight' ? 'day' : 'moonlight')
        : (cur === 'night'     ? 'sun' : 'night'));
      return;
    }

    if (t.closest('#coffee-toggle')) {
      const cur = root.getAttribute('data-theme') ?? 'night';
      const light = cur === 'sun' || cur === 'day';
      applyTheme(isCoffeeMode(cur)
        ? (light ? 'sun'      : 'night')
        : (light ? 'day'      : 'moonlight'));
      return;
    }

    if (t.closest('#hamburger-btn')) {
      const btn = document.getElementById('hamburger-btn')!;
      const overlay = document.getElementById('mobile-nav-overlay')!;
      const opening = !btn.classList.contains('open');
      btn.classList.toggle('open', opening);
      btn.setAttribute('aria-expanded', String(opening));
      overlay.classList.toggle('open', opening);
      overlay.setAttribute('aria-hidden', String(!opening));
      document.body.style.overflow = opening ? 'hidden' : '';
      return;
    }

    // Close nav when a link inside the overlay is tapped
    if (t.closest('#mobile-nav-overlay a')) {
      closeNav();
    }
  });

  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeNav(); });
</script>

<style>
/* ── Base header ── */
header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.6rem 1.5rem;
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--rule);
  background: var(--paper);
  transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}

header.scrolled {
  background: var(--paper-glass);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 1px 0 var(--rule);
}

/* ── Site name ── */
.site-name {
  font-family: var(--font-mono);
  font-size: var(--t-base);
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--royal-red);
  text-decoration: none;
  background-image: none;
  min-width: 0;
  display: flex;
  align-items: baseline;
}
.site-name:hover { background-image: none; background: var(--royal-red); color: var(--paper); }
.site-wordmark   { white-space: nowrap; }
.site-persian    { font-family: var(--font-naskh); font-style: normal; letter-spacing: 0; }

.cursor {
  display: inline-block;
  animation: blink 1s step-end infinite;
  color: var(--ink);
  margin-left: 1px;
}

.reading-title {
  display: none;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 55vw;
  font-size: var(--t-sm);
  font-weight: 600;
  letter-spacing: 0.04em;
  color: var(--ink);
}

/* ── Desktop nav ── */
.desktop-nav { display: flex; gap: 1.25rem; align-items: center; }
.desktop-nav a { font-family: var(--font-mono); font-size: var(--t-sm); color: var(--ink-dim); letter-spacing: 0.04em; }
.desktop-nav a:hover,
.desktop-nav a.active { background-size: 100% 100%; color: var(--paper); }

/* ── Controls — fixed outside header to escape backdrop-filter stacking context ── */
.header-controls {
  position: fixed;
  top: 0;
  right: 1.5rem;
  z-index: 200;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 1.25rem 0;
}

.theme-toggle {
  font-family: var(--font-mono);
  font-size: var(--t-base);
  background: none;
  border: 1px solid var(--rule);
  color: var(--ink-dim);
  cursor: pointer;
  padding: 0.15rem 0.5rem;
  line-height: 1;
  transition: border-color 0.2s, color 0.2s, background 0.2s, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.theme-toggle:hover  { border-color: var(--ink); color: var(--paper); background: var(--ink); }
.theme-toggle:active { transform: scale(0.93); }

.coffee-toggle {
  background: none;
  border: 1px solid var(--rule);
  color: var(--ink-dim);
  cursor: pointer;
  padding: 0.25rem 0.45rem;
  line-height: 0;
  display: inline-flex;
  align-items: center;
  transition: border-color 0.2s, color 0.2s, background 0.2s, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.coffee-toggle.active,
.coffee-toggle:hover  { border-color: var(--ink); color: var(--paper); background: var(--ink); }
.coffee-toggle:active { transform: scale(0.93); }

/* ── Hamburger + overlay — desktop: completely hidden ── */
.hamburger,
.mobile-nav-overlay { display: none; }

/* ═══════════════════════════════════════════
   MOBILE  (≤ 680px)
   ═══════════════════════════════════════════ */
@media (max-width: 680px) {

  /* Compact single-row header */
  header { padding: 0.7rem 1rem; gap: 0; flex-wrap: nowrap; }
  .desktop-nav { display: none; }

  .site-name {
    flex: 1;
    min-width: 0;
    font-size: calc(var(--t-base) * 0.75);
    letter-spacing: 0.08em;
  }

  /* Reading mode */
  header.reading-mode .site-wordmark { display: none; }
  header.reading-mode .reading-title { display: block; }

  /* ── Floating pill — vertically centered on right edge ── */
  .header-controls {
    flex-direction: column;
    top: 50dvh;
    right: 0.75rem;
    transform: translateY(-50%);
    gap: 0.25rem;
    padding: 0.4rem 0.35rem;
    background: var(--paper-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--rule);
    border-radius: 999px;
    z-index: 300;
  }

  .header-controls .theme-toggle {
    border: none;
    font-size: var(--t-sm);
    padding: 0.25rem 0.4rem;
  }

  .header-controls .coffee-toggle {
    border: none;
    padding: 0.25rem 0.35rem;
  }

  /* ── Hamburger — fixed top-right, above overlay ── */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    position: fixed;
    top: 0.6rem;
    right: 1rem;
    z-index: 310;
    background: none;
    border: 1px solid var(--rule);
    color: var(--ink-dim);
    cursor: pointer;
    padding: 0.45rem 0.5rem;
    transition: border-color 0.2s, color 0.2s;
  }
  .hamburger:hover { border-color: var(--ink); color: var(--ink); }

  .hamburger span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: currentColor;
    transition: transform 0.2s ease, opacity 0.15s ease;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Full-screen nav overlay ──
     Always display:flex on mobile; hidden via opacity+visibility so
     CSS transitions work correctly (display:none kills transitions). */
  .mobile-nav-overlay {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: var(--paper);
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.22s ease, visibility 0s linear 0.22s;
  }
  .mobile-nav-overlay.open {
    visibility: visible;
    opacity: 1;
    transition: opacity 0.22s ease, visibility 0s linear 0s;
  }

  .mobile-nav-overlay nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  .mobile-nav-overlay nav a {
    font-family: var(--font-mono);
    font-size: var(--t-xl);
    color: var(--ink-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background-image: none;
    padding: 0.5rem 1rem;
    transition: color 0.15s ease;
  }
  .mobile-nav-overlay nav a:hover,
  .mobile-nav-overlay nav a.active {
    color: var(--ink);
    background: none;
    background-image: none;
  }
}
</style>
