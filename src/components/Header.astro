---
const nav = [
  { href: '/essays', label: 'essays' },
  { href: '/stories', label: 'stories' },
  { href: '/about', label: 'about' },
];
const current = Astro.url.pathname;
---
<header>
  <a class="site-name" href="/">
    THE TRUTH · حقیقت<span class="cursor" aria-hidden="true">▌</span>
  </a>
  <div class="header-right">
    <nav>
      {nav.map(({ href, label }) => (
        <a href={href} class:list={[{ active: current.startsWith(href) }]}>
          [{label}]
        </a>
      ))}
    </nav>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle day/night mode" title="Toggle day/night">
      <span class="theme-icon">◑</span>
    </button>
  </div>
</header>

<script>
  const root = document.documentElement;
  const btn = document.getElementById('theme-toggle');
  const icon = btn?.querySelector('.theme-icon');

  const cycle: string[] = ['night', 'moonlight', 'day', 'sun'];

  const saved = localStorage.getItem('theme') ?? 'night';
  applyTheme(saved);

  btn?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme') ?? 'night';
    const next = cycle[(cycle.indexOf(current) + 1) % cycle.length];
    applyTheme(next);
    localStorage.setItem('theme', next);
  });

  function applyTheme(theme: string) {
    if (theme === 'night') {
      root.removeAttribute('data-theme');
      if (icon) icon.textContent = '◑';
    } else {
      root.setAttribute('data-theme', theme);
      if (icon) icon.textContent = theme === 'moonlight' ? '☽' : theme === 'sun' ? '☀' : '○';
    }
  }
</script>

<style>
header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
  padding: 1.5rem;
  border-bottom: 1px solid var(--rule);
  transition: border-color 0.3s ease;
}

.site-name {
  font-family: var(--font-mono);
  font-size: var(--t-base);
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--ink-bright);
  text-decoration: none;
  background-image: none;
}

.site-name:hover {
  background-image: none;
  background: var(--ink-bright);
  color: var(--paper);
}

.cursor {
  display: inline-block;
  animation: blink 1s step-end infinite;
  color: var(--ink);
  margin-left: 1px;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

nav {
  display: flex;
  gap: 1.25rem;
}

nav a {
  font-family: var(--font-mono);
  font-size: var(--t-sm);
  color: var(--ink-dim);
  letter-spacing: 0.04em;
}

nav a:hover,
nav a.active {
  background-size: 100% 100%;
  color: var(--paper);
}

.theme-toggle {
  font-family: var(--font-mono);
  font-size: var(--t-base);
  background: none;
  border: 1px solid var(--rule);
  color: var(--ink-dim);
  cursor: pointer;
  padding: 0.15rem 0.5rem;
  line-height: 1;
  transition: border-color 0.2s, color 0.2s, background 0.2s;
}

.theme-toggle:hover {
  border-color: var(--ink);
  color: var(--paper);
  background: var(--ink);
}
</style>
