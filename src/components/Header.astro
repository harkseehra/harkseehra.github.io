---
const nav = [
  { href: '/essays', label: 'articles' },
  { href: '/stories', label: 'stories' },
  { href: '/about', label: 'about' },
];
const current = Astro.url.pathname;
---
<header id="site-header">
  <a class="site-name" href="/">
    THE TRUTH · حقیقت<span class="cursor" aria-hidden="true">▌</span>
  </a>
  <nav>
    {nav.map(({ href, label }) => (
      <a href={href} class:list={[{ active: current.startsWith(href) }]}>
        [{label}]
      </a>
    ))}
  </nav>
  <div class="header-controls">
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle day/night mode" title="Toggle day/night">
      <span class="theme-icon">◑</span>
    </button>
    <button class="coffee-toggle" id="coffee-toggle" aria-label="Toggle coffee mode" title="Coffee mode">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M17 8h1a4 4 0 0 1 0 8h-1"/>
        <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/>
        <line x1="6" y1="2" x2="6" y2="4"/>
        <line x1="10" y1="2" x2="10" y2="4"/>
        <line x1="14" y1="2" x2="14" y2="4"/>
      </svg>
    </button>
  </div>
</header>

<script>
  const root = document.documentElement;
  const btn = document.getElementById('theme-toggle');
  const icon = btn?.querySelector('.theme-icon');
  const coffeeBtn = document.getElementById('coffee-toggle');

  // Coffee mode = warm variants: moonlight (dark) and day (light)
  // Standard mode = clean variants: night (dark) and sun (light)
  function isCoffeeMode(theme: string): boolean {
    return theme === 'moonlight' || theme === 'day';
  }

  function syncIcon(theme: string) {
    const icons: Record<string, string> = { night: '◑', moonlight: '☽', sun: '☀', day: '○' };
    if (icon) icon.textContent = icons[theme] ?? '◑';
    coffeeBtn?.classList.toggle('active', isCoffeeMode(theme));
  }

  function applyTheme(theme: string) {
    localStorage.setItem('theme', theme);
    if (theme === 'night') {
      root.removeAttribute('data-theme');
    } else {
      root.setAttribute('data-theme', theme);
    }
    syncIcon(theme);
  }

  // Sync icon to whatever the inline script already set
  syncIcon(root.getAttribute('data-theme') ?? 'night');

  // Day/night toggle: flip between dark↔light within the current mode pair
  btn?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme') ?? 'night';
    applyTheme(isCoffeeMode(current)
      ? (current === 'moonlight' ? 'day' : 'moonlight')  // coffee:   moonlight ↔ day
      : (current === 'night'     ? 'sun' : 'night'));     // standard: night ↔ sun
  });

  // Coffee toggle: switch between standard and warm variant of the current dark/light state
  coffeeBtn?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme') ?? 'night';
    const isLight = current === 'sun' || current === 'day';
    applyTheme(isCoffeeMode(current)
      ? (isLight ? 'sun'      : 'night')      // exit coffee:  day→sun, moonlight→night
      : (isLight ? 'day'      : 'moonlight'   // enter coffee: sun→day, night→moonlight
    ));
  });
</script>

<style>
header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.6rem 1.5rem;
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--rule);
  background: var(--paper);
  transition: background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
}

header.scrolled {
  background: var(--paper-glass);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: 0 1px 0 var(--rule);
}

.site-name {
  font-family: var(--font-mono);
  font-size: var(--t-base);
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--royal-red);
  text-decoration: none;
  background-image: none;
}

.site-name:hover {
  background-image: none;
  background: var(--royal-red);
  color: var(--paper);
}

.cursor {
  display: inline-block;
  animation: blink 1s step-end infinite;
  color: var(--ink);
  margin-left: 1px;
}

nav {
  display: flex;
  gap: 1.25rem;
  align-items: center;
}

nav a {
  font-family: var(--font-mono);
  font-size: var(--t-sm);
  color: var(--ink-dim);
  letter-spacing: 0.04em;
}

nav a:hover,
nav a.active {
  background-size: 100% 100%;
  color: var(--paper);
}

.header-controls {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.theme-toggle {
  font-family: var(--font-mono);
  font-size: var(--t-base);
  background: none;
  border: 1px solid var(--rule);
  color: var(--ink-dim);
  cursor: pointer;
  padding: 0.15rem 0.5rem;
  line-height: 1;
  transition: border-color 0.2s, color 0.2s, background 0.2s, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.theme-toggle:hover {
  border-color: var(--ink);
  color: var(--paper);
  background: var(--ink);
}

.theme-toggle:active {
  transform: scale(0.93);
}

.coffee-toggle {
  background: none;
  border: 1px solid var(--rule);
  color: var(--ink-dim);
  cursor: pointer;
  padding: 0.25rem 0.45rem;
  line-height: 0;
  display: inline-flex;
  align-items: center;
  transition: border-color 0.2s, color 0.2s, background 0.2s, transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.coffee-toggle.active,
.coffee-toggle:hover {
  border-color: var(--ink);
  color: var(--paper);
  background: var(--ink);
}

.coffee-toggle:active {
  transform: scale(0.93);
}

@media (max-width: 680px) {
  header {
    padding: 1rem 1.25rem;
    gap: 0;
  }

  .site-name {
    flex: 1;
  }

  nav {
    order: 3;
    width: 100%;
    gap: 1.1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--rule);
    margin-top: 0.5rem;
  }
}
</style>
